{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "pubDate": {
      "type": "string",
      "format": "date-time"
    },
    "updatedDate": {
      "type": "string",
      "format": "date-time"
    },
    "author": {
      "default": "Equipo Guira",
      "type": "string"
    },
    "authorRole": {
      "default": "Equipo Editorial",
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "readingTime": {
      "type": "number"
    },
    "featured": {
      "default": false,
      "type": "boolean"
    },
    "image": {
      "type": "string"
    },
    "imageAlt": {
      "type": "string"
    },
    "keywords": {
      "type": "string"
    },
    "excerpt": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "pubDate",
    "category",
    "tags",
    "readingTime"
  ]
}