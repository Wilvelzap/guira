---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Plataforma Operativa en USD para Empresas de LATAM | Guira Empresas"
  description="Guira Empresas es la plataforma B2B para que agencias, exportadoras e importadoras de LATAM operen internacionalmente en USD: recepción de pagos, trazabilidad operativa y pagos a proveedores desde una sola interfaz."
  keywords="plataforma de pagos internacional, cuenta internacional para empresas, cuenta en USD para empresas, recibir pagos en USD, recibir pagos desde Estados Unidos, pagos empresariales internacionales, fintech para empresas en LATAM, pagos a proveedores Bolivia, empresa boliviana pagar proveedor extranjero, pagar proveedores internacionales desde Bolivia, cuenta en USD para empresas bolivianas"
  canonicalUrl="https://www.guiracorp.com/"
  activeLink="index"
  footerTheme="rich-dark"
>
  <Fragment slot="head">
    <!-- Schema: Organization + WebSite -->
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FinancialService",
      "name": "Guira Empresas",
      "alternateName": "Guira System LLC",
      "url": "https://www.guiracorp.com",
      "description": "Plataforma operativa B2B con sede en EE.UU. para pagos empresariales internacionales en USD. Centraliza la recepción de pagos, visibilidad operativa y pagos a proveedores mediante ACH o Wire para empresas de LATAM.",
      "logo": "https://www.guiracorp.com/guira-logo.svg",
      "image": "https://www.guiracorp.com/assets/images/og-image.jpg",
      "telephone": "+13057681048",
      "email": "administracion@guiracorp.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "1201 North Market Street #111",
        "addressLocality": "Wilmington",
        "addressRegion": "Delaware",
        "postalCode": "19801",
        "addressCountry": "US"
      },
      "areaServed": [
        { "@type": "Place", "name": "América Latina" },
        { "@type": "Country", "name": "Bolivia" },
        { "@type": "Country", "name": "Colombia" },
        { "@type": "Country", "name": "Perú" },
        { "@type": "Country", "name": "México" }
      ],
      "contactPoint": [
        {
          "@type": "ContactPoint",
          "telephone": "+13057681048",
          "contactType": "sales",
          "areaServed": "LATAM",
          "availableLanguage": "Spanish"
        },
        {
          "@type": "ContactPoint",
          "telephone": "+59175245845",
          "contactType": "customer support",
          "areaServed": "BO",
          "availableLanguage": "Spanish"
        }
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Servicios Financieros Empresariales",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Cuenta Virtual en USD para Empresas",
              "description": "Recibe pagos en USD desde Estados Unidos con datos de recepción en tu nombre corporativo."
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Pagos empresariales ACH y Wire",
              "description": "Instruye pagos a proveedores internacionales mediante ACH o Wire con trazabilidad completa."
            }
          }
        ]
      },
      "sameAs": []
    }
    </script>
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Guira Empresas",
      "url": "https://www.guiracorp.com"
    }
    </script>
    <link rel="preload" as="image" href="/assets/images/hero-ejecutivo.webp" type="image/webp" />
  </Fragment>

  <!-- Hero -->
  <header class="relative pt-36 pb-24 overflow-hidden border-b border-slate-200">
      <div class="absolute inset-0">
          <picture class="w-full h-full block">
              <source srcset="/assets/images/hero-ejecutivo.webp" type="image/webp" fetchpriority="high">
              <img src="/assets/images/hero-ejecutivo.jpg" alt="" class="w-full h-full object-cover object-center" aria-hidden="true" fetchpriority="high">
          </picture>
          <div class="absolute inset-0 bg-gradient-to-r from-white via-white/95 to-white/60"></div>
          <div class="absolute inset-0 bg-gradient-to-b from-white/80 via-transparent to-white/80"></div>
      </div>
      <div
          class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(0,81,255,0.07),transparent_32%),radial-gradient(circle_at_80%_10%,rgba(0,216,255,0.06),transparent_26%)]">
      </div>
      <div
          class="absolute inset-0 opacity-60 bg-[linear-gradient(rgba(15,23,42,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(15,23,42,0.03)_1px,transparent_1px)] bg-[size:72px_72px] animate-pulse-grid">
      </div>
      <div class="fintech-orb w-72 h-72 bg-guira-teal/30 top-24 left-8" data-parallax="26"></div>
      <div class="fintech-orb w-64 h-64 bg-guira-cyan/30 top-20 right-10 [animation-delay:1.2s]" data-parallax="18">
      </div>
      <div class="fintech-orb w-52 h-52 bg-slate-200/70 bottom-12 right-1/4 [animation-delay:2.2s]"
          data-parallax="12"></div>

      <div class="max-w-7xl mx-auto px-6 relative z-10 grid lg:grid-cols-[1.1fr_0.9fr] gap-14 items-center">
          <div class="text-left">
              <div class="reveal">
                  <span
                      class="fintech-badge inline-flex items-center gap-2 px-4 py-2 rounded-full text-xs font-bold text-guira-teal mb-8">
                      <span class="signal-dot w-2 h-2 rounded-full bg-guira-teal"></span>
                      Plataforma tecnológica para empresas de LATAM · Presencia en Bolivia
                  </span>
              </div>

              <!-- Hero Headline Actualizado -->
              <h1
                  class="reveal reveal-delay-1 text-4xl md:text-6xl font-extrabold tracking-tight mb-6 leading-[1.12] text-slate-900 max-w-3xl">
                  Plataforma operativa para pagos empresariales internacionales
              </h1>

              <!-- Hero Subheadline Actualizado -->
              <p
                  class="reveal reveal-delay-2 text-base md:text-lg text-slate-500 mb-10 max-w-xl font-medium leading-relaxed">
                  Centraliza la recepción, visibilidad y las instrucciones de pago de tu empresa, soportado por una
                  infraestructura documental y partners internacionales calificados.
              </p>

              <div class="reveal reveal-delay-3 flex flex-col sm:flex-row items-center sm:items-stretch gap-4 mb-10">
                  <a href="https://app.guiracorp.com"
                      class="w-full sm:w-auto px-8 py-4 bg-slate-900 text-white rounded-xl font-bold text-lg hover:bg-slate-800 transition-all shadow-xl shadow-slate-900/20 hover:-translate-y-1 flex items-center justify-center gap-2">
                      Comenzar Onboarding Empresarial
                      <i data-lucide="arrow-right" class="w-5 h-5"></i>
                  </a>
                  <a href="/demo"
                      class="w-full sm:w-auto px-8 py-4 bg-white text-slate-700 border border-slate-200 rounded-xl font-bold text-lg hover:bg-slate-50 transition-all shadow-sm hover:-translate-y-1">
                      Hablar con Ventas
                  </a>
              </div>

              <div class="reveal reveal-delay-4 grid sm:grid-cols-3 gap-4 max-w-3xl">
                  <div class="premium-card fintech-stat rounded-2xl p-5 tilt-card" data-tilt>
                      <p class="text-xs font-bold text-slate-400 section-kicker mb-3">Onboarding</p>
                      <p class="text-2xl font-extrabold text-slate-900 mb-1">Empresarial</p>
                      <p class="text-sm font-medium text-slate-500">Validación KYB diseñada para negocios de LATAM.
                      </p>
                  </div>
                  <div class="premium-card fintech-stat rounded-2xl p-5 tilt-card" data-tilt>
                      <p class="text-xs font-bold text-slate-400 section-kicker mb-3">Canales</p>
                      <p class="text-2xl font-extrabold text-slate-900 mb-1">ACH / Wire</p>
                      <p class="text-sm font-medium text-slate-500">Estructura para habilitar la recepción y envío de
                          pagos.</p>
                  </div>
                  <div class="premium-card fintech-stat rounded-2xl p-5 tilt-card" data-tilt>
                      <p class="text-xs font-bold text-slate-400 section-kicker mb-3">Control</p>
                      <p class="text-2xl font-extrabold text-slate-900 mb-1">Trazabilidad</p>
                      <p class="text-sm font-medium text-slate-500">Visibilidad clara y estructurada de cada flujo.
                      </p>
                  </div>
              </div>

          </div>

          <!-- Hero Mockup Protagonista -->
          <div class="mt-20 lg:mt-0 relative mx-auto max-w-5xl reveal reveal-delay-4">
              <div class="absolute -top-10 -left-6 fintech-badge rounded-2xl p-4 w-56 animate-float-soft z-20 tilt-card"
                  data-tilt>
                  <div class="flex items-center justify-between mb-3">
                      <span class="text-xs font-bold text-slate-400 section-kicker">Conciliación</span>
                      <span class="inline-flex items-center gap-1 text-[11px] font-bold text-emerald-600">
                          <span class="w-2 h-2 rounded-full bg-emerald-500"></span> Activo
                      </span>
                  </div>
                  <div class="text-2xl font-extrabold text-slate-900">$248K</div>
                  <div class="text-xs font-medium text-slate-500 mt-1">Operaciones conciliadas esta semana</div>
              </div>
              <div class="absolute -bottom-8 -right-4 fintech-badge rounded-2xl p-5 w-64 animate-float-soft [animation-delay:1.2s] z-20 tilt-card"
                  data-tilt>
                  <div class="text-xs font-bold text-slate-400 section-kicker mb-3">Soporte Documental</div>
                  <div class="flex items-center gap-3">
                      <div
                          class="w-12 h-12 rounded-2xl bg-emerald-100 text-emerald-600 flex items-center justify-center">
                          <i data-lucide="file-check-2" class="w-6 h-6"></i>
                      </div>
                      <div>
                          <div class="text-sm font-bold text-slate-900">Invoice Asociado</div>
                          <div class="text-xs text-slate-500 font-medium">Trazabilidad por operación</div>
                      </div>
                  </div>
              </div>
              <div class="premium-card rounded-[32px] border border-slate-200 shadow-[0_30px_80px_-32px_rgba(15,23,42,0.45)] overflow-hidden tilt-card"
                  data-tilt role="img" aria-label="Mockup de la plataforma corporativa Guira Empresas">
                  <div class="h-12 border-b border-slate-100 flex items-center px-4 bg-slate-50">
                      <div class="flex gap-2">
                          <div class="w-3 h-3 rounded-full bg-slate-300"></div>
                          <div class="w-3 h-3 rounded-full bg-slate-300"></div>
                          <div class="w-3 h-3 rounded-full bg-slate-300"></div>
                      </div>
                      <div class="mx-auto flex-1 max-w-md mx-4">
                          <div
                              class="bg-white rounded-md px-3 py-1.5 flex items-center gap-2 border border-slate-200 shadow-sm justify-center">
                              <i data-lucide="lock" class="w-3 h-3 text-slate-400"></i>
                              <span class="text-xs font-medium text-slate-500">app.guiracorp.com/dashboard</span>
                          </div>
                      </div>
                  </div>
                  <!-- Mockup Body -->
                  <div class="flex h-[470px]">
                      <!-- Sidebar -->
                      <div class="w-64 border-r border-slate-100 p-6 hidden md:block bg-slate-50/50">
                          <div class="flex items-center gap-3 mb-8">
                              <div
                                  class="w-10 h-10 rounded-xl bg-slate-900 flex items-center justify-center font-bold text-white shadow-md">
                                  AE</div>
                              <div>
                                  <div class="text-sm font-bold text-slate-900">Agencia Export</div>
                                  <div class="text-xs text-slate-500 font-medium">Business #4829</div>
                              </div>
                          </div>
                          <div class="space-y-1">
                              <div
                                  class="px-4 py-2.5 rounded-lg text-sm font-bold bg-slate-900 text-white shadow-md flex items-center gap-3">
                                  <i data-lucide="layout-dashboard" class="w-4 h-4 text-guira-teal"></i> Dashboard
                              </div>
                              <div
                                  class="px-4 py-2.5 rounded-lg text-sm font-medium text-slate-600 flex items-center gap-3">
                                  <i data-lucide="landmark" class="w-4 h-4"></i> Flujos Operativos
                              </div>
                              <div
                                  class="px-4 py-2.5 rounded-lg text-sm font-medium text-slate-600 flex items-center gap-3">
                                  <i data-lucide="arrow-right-left" class="w-4 h-4"></i> Transferencias
                              </div>
                              <div
                                  class="px-4 py-2.5 rounded-lg text-sm font-medium text-slate-600 flex items-center gap-3">
                                  <i data-lucide="shield-check" class="w-4 h-4"></i> Compliance
                              </div>
                          </div>
                      </div>
                      <!-- Main Content -->
                      <div class="flex-1 p-8 bg-white text-left relative overflow-hidden">
                          <div
                              class="absolute top-5 right-6 flex items-center gap-2 text-[11px] font-bold text-emerald-600 bg-emerald-50 px-4 py-2 rounded-full border border-emerald-100 whitespace-nowrap">
                              <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
                              Operación estable
                          </div>
                          <h2 class="text-slate-500 text-sm font-bold mb-1 uppercase tracking-wider">Balance Operativo
                              Digital</h2>
                          <div class="text-4xl font-extrabold text-slate-900 flex items-center gap-3 mb-1">
                              $124,500.00 <span
                                  class="text-xs font-bold text-guira-teal bg-guira-teal/10 px-2 py-1 rounded">USD *</span>
                          </div>
                          <p class="text-[10px] text-slate-400 mb-8">* Valores de simulación referenciales</p>

                          <div class="grid grid-cols-3 gap-3 mb-6">
                              <div class="rounded-xl bg-slate-50 border border-slate-200 p-4">
                                  <p class="text-[10px] font-bold uppercase tracking-[0.22em] text-slate-400 mb-1">Red
                                      Operativa</p>
                                  <p class="text-sm font-bold text-slate-900">ACH / Wire</p>
                              </div>
                              <div class="rounded-xl bg-slate-50 border border-slate-200 p-4">
                                  <p class="text-[10px] font-bold uppercase tracking-[0.22em] text-slate-400 mb-1">
                                      Risk</p>
                                  <p class="text-sm font-bold text-slate-900">Monitoreado</p>
                              </div>
                              <div class="rounded-xl bg-slate-50 border border-slate-200 p-4">
                                  <p class="text-[10px] font-bold uppercase tracking-[0.22em] text-slate-400 mb-1">
                                      Desk</p>
                                  <p class="text-sm font-bold text-slate-900">Corporate</p>
                              </div>
                          </div>

                          <div class="grid grid-cols-2 gap-6 mb-8">
                              <div class="p-5 rounded-xl border border-slate-200 bg-slate-50/50">
                                  <div class="text-sm font-bold text-slate-700 mb-1">Recibir de EE.UU.</div>
                                  <div class="text-xs text-slate-500 mb-3">Vía ACH o Wire Transfer</div>
                                  <button
                                      class="w-full py-2 bg-white border border-slate-200 rounded-lg text-xs font-bold shadow-sm hover:bg-slate-50 transition-colors">Ver
                                      Detalles de Recepción</button>
                              </div>
                              <div class="p-5 rounded-xl border border-slate-200 bg-slate-50/50">
                                  <div class="text-sm font-bold text-slate-700 mb-1">Enrutar Fondos</div>
                                  <div class="text-xs text-slate-500 mb-3">A Cuenta Local o Proveedores</div>
                                  <button
                                      class="w-full py-2 bg-slate-900 text-white border border-slate-900 rounded-lg text-xs font-bold shadow-sm hover:bg-slate-800 transition-colors">Instruir
                                      Salida</button>
                              </div>
                          </div>

                          <div>
                              <h3 class="text-sm font-bold text-slate-900 mb-3">Últimas Transacciones</h3>
                              <div class="space-y-3">
                                  <div class="flex justify-between items-center pb-3 border-b border-slate-100">
                                      <div class="flex items-center gap-3">
                                          <div
                                              class="w-8 h-8 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center">
                                              <i data-lucide="arrow-down-left" class="w-4 h-4"></i>
                                          </div>
                                          <div>
                                              <div class="text-sm font-bold text-slate-900">Transferencia Entrante
                                                  (Stripe)</div>
                                              <div class="text-xs text-slate-500">ACH In • Hoy</div>
                                          </div>
                                      </div>
                                      <div class="text-sm font-bold text-emerald-600">+$12,450.00</div>
                                  </div>
                                  <div class="flex justify-between items-center">
                                      <div class="flex items-center gap-3">
                                          <div
                                              class="w-8 h-8 rounded-full bg-slate-100 text-slate-600 flex items-center justify-center">
                                              <i data-lucide="arrow-up-right" class="w-4 h-4"></i>
                                          </div>
                                          <div>
                                              <div class="text-sm font-bold text-slate-900">Instrucción de salida
                                                  operativa
                                              </div>
                                              <div class="text-xs text-slate-500">Operación B2B • Ayer</div>
                                          </div>
                                      </div>
                                      <div class="text-sm font-bold text-slate-900">-$5,000.00</div>
                                  </div>
                              </div>
                          </div>
                      </div>
                  </div>
              </div>
          </div>
      </div>
  </header>

  <!-- Bloque Presencia e Infraestructura -->
  <section class="py-12 bg-guira-navy border-b border-slate-800">
      <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-3 gap-8">
          <div class="flex items-center gap-4 reveal">
              <div
                  class="w-12 h-12 rounded-xl bg-slate-800 flex items-center justify-center text-slate-300 border border-slate-700">
                  <i data-lucide="building-2" class="w-6 h-6"></i>
              </div>
              <div>
                  <h3 class="font-bold text-white text-sm uppercase tracking-wider">Estructura Corporativa</h3>
                  <p class="text-slate-400 text-sm font-medium">Empresa matriz operativa en Delaware, EE.UU.</p>
              </div>
          </div>
          <div class="flex items-center gap-4 reveal reveal-delay-1">
              <div
                  class="w-12 h-12 rounded-xl bg-slate-800 flex items-center justify-center text-slate-300 border border-slate-700">
                  <i data-lucide="map-pin" class="w-6 h-6"></i>
              </div>
              <div>
                  <h3 class="font-bold text-white text-sm uppercase tracking-wider">Asesores en Bolivia</h3>
                  <p class="text-slate-400 text-sm font-medium">Equipo asesor local para empresas que quieren usar Guira.</p>
                  <a href="/pagos-proveedores-bolivia" class="text-guira-teal text-xs font-bold hover:underline mt-1 inline-block">Ver solución para Bolivia →</a>
              </div>
          </div>
          <div class="flex items-center gap-4 reveal reveal-delay-2">
              <div
                  class="w-12 h-12 rounded-xl bg-slate-800 flex items-center justify-center text-slate-300 border border-slate-700">
                  <i data-lucide="users" class="w-6 h-6"></i>
              </div>
              <div>
                  <h3 class="font-bold text-white text-sm uppercase tracking-wider">Acompañamiento B2B</h3>
                  <p class="text-slate-400 text-sm font-medium">Equipo humano consultivo y permanente.</p>
              </div>
          </div>
      </div>
  </section>

  <!-- Franja Confianza -->
  <section class="py-10 border-b border-slate-200 bg-white relative overflow-hidden">
      <div class="max-w-7xl mx-auto px-6">
          <p class="text-center text-xs font-bold tracking-widest text-slate-400 uppercase mb-8">Infraestructura
              desarrollada para escalar tu operación internacional</p>
          <div class="relative overflow-hidden">
              <div
                  class="absolute inset-y-0 left-0 w-20 bg-gradient-to-r from-white to-transparent z-10 pointer-events-none">
              </div>
              <div
                  class="absolute inset-y-0 right-0 w-20 bg-gradient-to-l from-white to-transparent z-10 pointer-events-none">
              </div>
              <div class="marquee-track">
                  <div class="marquee-chip"><i data-lucide="check-circle" class="w-4 h-4 text-guira-teal"></i>
                      Validación empresarial según perfil</div>
                  <div class="marquee-chip"><i data-lucide="file-check-2" class="w-4 h-4 text-guira-teal"></i> Soporte
                      documental y trazabilidad</div>
                  <div class="marquee-chip"><i data-lucide="arrow-right-left" class="w-4 h-4 text-guira-teal"></i>
                      Operación entre rieles habilitados</div>
                  <div class="marquee-chip"><i data-lucide="building-2" class="w-4 h-4 text-guira-teal"></i>
                      Experiencia diseñada para empresas</div>
                  <div class="marquee-chip"><i data-lucide="check-circle" class="w-4 h-4 text-guira-teal"></i>
                      Validación empresarial según perfil</div>
                  <div class="marquee-chip"><i data-lucide="file-check-2" class="w-4 h-4 text-guira-teal"></i> Soporte
                      documental y trazabilidad</div>
                  <div class="marquee-chip"><i data-lucide="arrow-right-left" class="w-4 h-4 text-guira-teal"></i>
                      Operación entre rieles habilitados</div>
                  <div class="marquee-chip"><i data-lucide="building-2" class="w-4 h-4 text-guira-teal"></i>
                      Experiencia diseñada para empresas</div>
              </div>
          </div>
      </div>
  </section>

  <!-- Banner Visual LATAM -->
  <section class="relative h-72 md:h-96 overflow-hidden">
      <picture class="w-full h-full block">
          <source srcset="/assets/images/sobre-ciudad-latam.webp" type="image/webp">
          <img src="/assets/images/sobre-ciudad-latam.jpg" alt="Infraestructura financiera para empresas de LATAM" class="w-full h-full object-cover object-center" loading="lazy">
      </picture>
      <div class="absolute inset-0 bg-gradient-to-r from-guira-navy/90 via-guira-navy/60 to-transparent"></div>
      <div class="absolute inset-0 flex items-center">
          <div class="max-w-7xl mx-auto px-6">
              <p class="text-xs font-bold tracking-widest text-guira-teal uppercase mb-3">Presencia en LATAM</p>
              <h2 class="text-2xl md:text-4xl font-extrabold text-white max-w-xl leading-tight">Conectando empresas de la región con la economía global en USD.</h2>
          </div>
      </div>
  </section>

  <!-- Problema / Solución (Fondo Oscuro Alto Contraste) -->
  <section class="py-24 bg-guira-navy border-y border-white/5 relative overflow-hidden">
      <div
          class="absolute top-0 right-1/4 w-[600px] h-[600px] bg-guira-teal opacity-[0.03] blur-[120px] rounded-full pointer-events-none">
      </div>
      <div class="max-w-7xl mx-auto px-6 relative z-10">
          <div class="text-center mb-16 reveal">
              <h2 class="text-3xl md:text-5xl font-extrabold mb-6 text-white">El desafío de operar
                  globalmente,<br /><span class="text-slate-400">resuelto de forma nativa.</span></h2>
              <p class="text-slate-400 max-w-2xl mx-auto text-lg font-medium">Abrir una cuenta bancaria internacional
                  requiere presencia física, tiempo y altos costos. Guira optimiza estos procesos integrando
                  infraestructura financiera robusta mediante software.</p>
          </div>
          <div class="grid md:grid-cols-2 gap-8">
