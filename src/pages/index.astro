                        class="w-full sm:w-auto px-10 py-5 bg-slate-800 text-white border border-slate-700 rounded-2xl font-bold text-lg hover:bg-slate-700 transition-all shadow-sm hover:-translate-y-1"
                        >Solicitar demo</a
                    >
                    <a
                        href="/contacto"
                        class="w-full sm:w-auto px-10 py-5 bg-white/5 text-white border border-white/10 rounded-2xl font-bold text-lg hover:bg-white/10 transition-all shadow-sm hover:-translate-y-1"
                        >Hablar con ventas</a
                    >
                </div>
            </div>
        </section>
        <style>
            .quote-destination-btn { display: flex; align-items: center; gap: 0.75rem; padding: 0.9rem 1.1rem; border-radius: 1rem; border: 1px solid rgb(226 232 240); background: #ffffff; color: rgb(51 65 85); text-align: left; transition: border-color 180ms ease, box-shadow 180ms ease, background-color 180ms ease; }
            .quote-destination-btn:hover { border-color: rgb(148 163 184); }
            .quote-destination-btn.active { border-color: #0051ff; background: rgba(0, 81, 255, 0.05); box-shadow: 0 8px 24px -12px rgba(0, 81, 255, 0.25); color: #0051ff; }
            .quote-destination-btn__title { display: block; font-size: 0.875rem; font-weight: 700; }
            .quote-destination-btn__meta { display: block; font-size: 0.75rem; font-weight: 600; color: rgb(148 163 184); }
            .quote-destination-btn.active .quote-destination-btn__meta { color: #0051ff; opacity: 0.7; }
            .product-explorer__grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1.5rem; }
            .product-explorer__card { min-height: 29rem; overflow: hidden; border: 1px solid rgb(226 232 240); border-radius: 1.5rem; background: white; text-align: left; transition: border-color 180ms ease, box-shadow 180ms ease, background-color 180ms ease; }
            .product-explorer__card:hover, .product-explorer__card:focus-visible { border-color: rgb(148 163 184); box-shadow: 0 20px 45px -32px rgba(15, 23, 42, 0.3); outline: none; }
            .product-explorer__card[aria-pressed="true"] { border-color: rgb(13 148 136); background: rgb(252 255 255); box-shadow: 0 20px 45px -30px rgba(13, 148, 136, 0.32); }
            .product-explorer__media { position: relative; height: 12.5rem; overflow: hidden; background: rgb(15 23 42); }
            .product-explorer__media::after { position: absolute; inset: 0; content: ""; background: linear-gradient(180deg, transparent 45%, rgba(15, 23, 42, 0.55)); }
            .product-explorer__media img, .product-explorer__media video { width: 100%; height: 100%; object-fit: cover; }
            .product-explorer__icon-wrap { display: flex; width: 2rem; height: 2rem; margin: 2rem 2rem 0; align-items: center; color: rgb(15 23 42); }
            .product-explorer__icon-wrap svg { width: 1.7rem; height: 1.7rem; stroke-width: 1.7; }
            .product-explorer__body { display: flex; min-height: 20rem; padding: 1.6rem 2rem 2rem; flex-direction: column; }
            .product-explorer__media + .product-explorer__body { min-height: 16.5rem; }
            .product-explorer__eyebrow { margin-bottom: 0.7rem; color: rgb(13 148 136); font-size: 0.68rem; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; }
            .product-explorer__title { margin: 0; color: rgb(15 23 42); font-size: 1.45rem; font-weight: 750; line-height: 1.25; }
            .product-explorer__text { margin: 1rem 0 1.5rem; color: rgb(71 85 105); font-size: 0.94rem; font-weight: 500; line-height: 1.65; }
            .product-explorer__points { margin-top: auto; padding-top: 1.25rem; border-top: 1px solid rgb(226 232 240); color: rgb(51 65 85); font-size: 0.82rem; font-weight: 700; line-height: 1.8; }
            .product-explorer__points span { display: block; }
            .product-explorer__points span::before { content: "✓"; margin-right: 0.55rem; color: rgb(13 148 136); }
            .product-explorer__hint { margin-top: 1.25rem; color: rgb(100 116 139); font-size: 0.875rem; font-weight: 600; text-align: center; }
            @media (max-width: 767px) { .product-explorer__grid { display: flex; overflow-x: auto; gap: 1rem; padding: 0.25rem 0.5rem 1rem; scroll-snap-type: x mandatory; scrollbar-width: none; } .product-explorer__grid::-webkit-scrollbar { display: none; } .product-explorer__card { min-width: min(84vw, 25rem); scroll-snap-align: center; } }
            @media (prefers-reduced-motion: reduce) { .product-explorer__card { transition: none; } }
        </style>

        <script>
            const quoteWidget = document.querySelector("[data-quote-widget]");

            if (quoteWidget) {
                const input = quoteWidget.querySelector("[data-quote-input]");
                const output = quoteWidget.querySelector("[data-quote-output]");
                const currencyLabel = quoteWidget.querySelector(
                    "[data-quote-currency-label]"
                );
                const note = quoteWidget.querySelector("[data-quote-note]");
                const destinationButtons = quoteWidget.querySelectorAll(
                    "[data-quote-destination]"
                );

                const formatAmount = (value) =>
                    value.toLocaleString("es-BO", {
                        minimumFractionDigits: 2,
                        maximumFractionDigits: 2,
                    });

                const recalculate = () => {
                    const active = quoteWidget.querySelector(
                        "[data-quote-destination].active"
                    );
                    if (!active) return;

                    const rawAmount = parseFloat(
                        (input.value || "0").replace(",", ".")
                    );
                    const amount = Number.isNaN(rawAmount) ? 0 : rawAmount;
                    const rate = parseFloat(active.dataset.rate || "1");
                    const currency = active.dataset.currency || "USD";
                    const title = active.querySelector(
                        ".quote-destination-btn__title"
                    ).textContent;

                    output.textContent = formatAmount(amount * rate);
                    currencyLabel.textContent = `${currency} · ${title}`;
                    note.textContent = active.dataset.note || "";
                };

                input.addEventListener("input", recalculate);

                destinationButtons.forEach((button) => {
                    button.addEventListener("click", () => {
                        destinationButtons.forEach((b) =>
                            b.classList.remove("active")
                        );
                        button.classList.add("active");
                        recalculate();
                    });
                });

                recalculate();
            }
        </script>

        <script>
            import { gsap } from "gsap";
            import { Flip } from "gsap/Flip";

            gsap.registerPlugin(Flip);

            const explorer = document.querySelector("[data-product-explorer]");

            if (explorer) {
                const grid = explorer.querySelector("[data-product-grid]");
                const status = explorer.querySelector("[data-product-status]");
                // Las tarjetas estáticas son un respaldo sin JavaScript. La experiencia
                // interactiva usa botones reales para conservar teclado y foco.
                const initialCards = [];
                grid.replaceChildren();
                const activeClass = "product-explorer__card";
                let activeSource = null;
                let isTransitioning = false;

                const products = [
                    {
                        id: "usd",
                        icon: "landmark",
                        eyebrow: "Cuenta operativa en USD",
                        title: "Infraestructura operativa en USD",
                        text: "Centraliza la recepción de pagos desde USA al integrarte con estructuras de pago reguladas, facilitando la visibilidad de tu flujo operativo internacional de inicio a fin.",
                        points: ["Datos de recepción en USD", "Recepción de pagos desde USA"],
                        mediaType: "image",
                        image: "/assets/images/plataforma-dashboard-monitor.webp",
                        detail: { mediaType: "image", image: "/assets/images/blog/dashboard-cobros-internacionales-trazabilidad.webp", title: "Cada cobro, con contexto", text: "Revisa la información de cada recepción y conserva una vista ordenada de tu operación internacional.", points: ["Referencia por operación", "Visibilidad de movimientos"] }
                    },
                    {
                        id: "payments",
                        icon: "globe-2",
                        eyebrow: "Pagos internacionales",
                        title: "Pagos empresariales",
                        text: "Ejecuta pagos ACH y Wire a proveedores y partners clave en Estados Unidos con total visibilidad, orden y trazabilidad operativa.",
                        points: ["Pagos ACH y Wire transfer", "Mayor orden y trazabilidad"],
                        mediaType: "image",
                        image: "/assets/images/blog/pagar-proveedores-internacionales-bolivia.webp",
                        detail: { mediaType: "image", image: "/assets/images/blog/factura-proveedor-internacional-banco.webp", title: "Del proveedor al comprobante", text: "Concentra los datos necesarios para preparar y seguir un pago internacional de tu empresa.", points: ["Datos del proveedor", "Soporte documental"] }
                    },
                    {
                        id: "routing",
                        icon: "refresh-cw",
                        eyebrow: "Flexibilidad operativa",
                        title: "Flexibilidad de salida",
                        text: "Instruye transferencias según la estructura aprobada hacia cuentas locales o canales digitales mediante una interfaz orientada al control documental.",
                        points: ["Opciones de enrutamiento operativo", "Soporte documental trazable por transacción"],
                        mediaType: "image",
                        image: "/assets/images/blog/seguimiento-operaciones-plataforma-digital.webp",
                        detail: { mediaType: "image", image: "/assets/images/blog/transferencia-internacional-documentos-usd.webp", title: "Una salida definida para cada caso", text: "Mantén el seguimiento de la instrucción y la documentación que corresponde a cada operación.", points: ["Seguimiento de instrucciones", "Documentación organizada"] }
                    }
                ];

                const nodes = new Map();

                const media = (product, type) => {
                    const content = type === "detail" ? product.detail : product;
                    const source = content.image;
                    const asset = content.mediaType === "video"
                        ? `<video src="${source}" muted playsinline loop autoplay preload="metadata"></video>`
                        : `<img src="${source}" alt="" loading="lazy" />`;
                    return `<div class="product-explorer__media">${asset}</div>`;
                };

                const createCard = (product, type, node) => {
                    const content = type === "detail" ? product.detail : product;
                    const card = node || document.createElement("button");
                    card.type = "button";
                    card.className = activeClass;
                    card.dataset.productId = product.id;
                    card.dataset.productType = type;
                    card.setAttribute("aria-pressed", "false");
                    const header = type === "detail"
                        ? media(product, type)
                        : `<div class="product-explorer__icon-wrap"><i data-lucide="${product.icon}" aria-hidden="true"></i></div>`;
                    card.innerHTML = `${header}<div class="product-explorer__body"><p class="product-explorer__eyebrow">${type === "detail" ? "Detalle de la capacidad" : product.eyebrow}</p><h3 class="product-explorer__title">${content.title}</h3><p class="product-explorer__text">${content.text}</p><div class="product-explorer__points">${content.points.map((point) => `<span>${point}</span>`).join("")}</div></div>`;
                    return card;
                };

                products.forEach((product, index) => {
                    const main = createCard(product, "main", initialCards[index]);
                    const detail = createCard(product, "detail");
                    nodes.set(`${product.id}:main`, main);
                    nodes.set(`${product.id}:detail`, detail);
                });

                if (window.lucide) window.lucide.createIcons();

                const originalOrder = products.map((product) => `${product.id}:main`);

                const render = (order, source = null) => {
                    const state = Flip.getState(grid.children);
                    // Saca del carril la tarjeta que debe abandonar uno de los tres espacios.
                    Array.from(grid.children).forEach((card) => {
                        const key = `${card.dataset.productId}:${card.dataset.productType}`;
                        if (!order.includes(key)) card.remove();
                    });
                    order.forEach((key) => grid.appendChild(nodes.get(key)));
                    grid.querySelectorAll("button").forEach((card) => {
                        const selected = source && card.dataset.productId === source;
                        card.setAttribute("aria-pressed", String(selected));
                    });

                    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
                    if (reducedMotion) {
                        isTransitioning = false;
                        return;
                    }

                    Flip.from(state, {
                        duration: 0.62,
                        ease: "power3.inOut",
                        absolute: true,
                        onEnter: (elements) => gsap.fromTo(elements, { autoAlpha: 0, x: 30 }, { autoAlpha: 1, x: 0, duration: 0.38, ease: "power2.out" }),
                        onLeave: (elements) => gsap.to(elements, { autoAlpha: 0, x: -30, duration: 0.22 }),
                        onComplete: () => { isTransitioning = false; }
                    });
                };

                grid.addEventListener("click", (event) => {
                    const card = event.target.closest("button[data-product-id]");
                    if (!card || isTransitioning) return;

                    const source = card.dataset.productId;
                    isTransitioning = true;

                    if (activeSource === source) {
                        activeSource = null;
                        status.textContent = "Vista inicial de capacidades restaurada.";
                        render(originalOrder);
                        return;
                    }

                    activeSource = source;
                    const selectedOrders = {
                        // La tarjeta elegida se desplaza y su pieza asociada ocupa su lugar.
                        // Solo hay tres espacios visibles. La cuarta tarjeta sale por un borde.
                        usd: ["usd:detail", "payments:main", "usd:main"],
                        payments: ["payments:main", "payments:detail", "routing:main"],
                        routing: ["payments:main", "routing:main", "routing:detail"]
                    };
                    const order = selectedOrders[source];
                    status.textContent = `Mostrando el detalle de ${products.find((product) => product.id === source).title}.`;
                    render(order, source);
                });

                render(originalOrder);
            }
        </script>
    </StackedSections>
</Layout>
