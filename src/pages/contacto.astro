---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contacto y Asesoría B2B | Guira Empresas"
  description="Habla con el equipo de Guira Empresas sobre recibir pagos en USD, pagar proveedores internacionales ACH/Wire o habilitar tu operación B2B desde LATAM. Asesores en Bolivia y EE.UU."
  keywords="contacto guira, hablar con ventas guira, soporte corporativo guira, asesoría B2B pagos internacionales, oficinas guira bolivia"
  canonicalUrl="https://www.guiracorp.com/contacto"
  footerTheme="light"
  copyright="Acompañamiento Corporativo. © 2026 Guira System LLC. Representado en Bolivia por Guiraglobal SRL. Todos los derechos reservados."
>
  <Fragment slot="head">
    <!-- Schema: ContactPage + BreadcrumbList -->
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "ContactPage",
      "name": "Contacto y Asesoría B2B | Guira Empresas",
      "description": "Habla con el equipo de Guira para recibir pagos en USD o pagar proveedores internacionales desde LATAM.",
      "url": "https://www.guiracorp.com/contacto",
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          {"@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://www.guiracorp.com/"},
          {"@type": "ListItem", "position": 2, "name": "Contacto", "item": "https://www.guiracorp.com/contacto"}
        ]
      },
      "mainEntity": {
        "@type": "FinancialService",
        "name": "Guira Empresas",
        "url": "https://www.guiracorp.com",
        "telephone": "+13057681048",
        "email": "administracion@guiracorp.com",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "1201 North Market Street #111",
          "addressLocality": "Wilmington",
          "addressRegion": "Delaware",
          "postalCode": "19801",
          "addressCountry": "US"
        }
      }
    }
    </script>
  </Fragment>

  <!-- Content -->
  <main class="pt-32 pb-24 flex-1 text-left">
      <div class="max-w-5xl mx-auto px-6 grid grid-cols-1 md:grid-cols-5 gap-10 md:gap-14">

          <div class="md:col-span-2 reveal-left space-y-8 mt-4">
              <div>
                  <h1 class="text-4xl font-extrabold text-slate-900 mb-4">Contacto: Recibe Pagos en USD o Paga Proveedores Internacionales desde LATAM</h1>
                  <p class="text-slate-600 font-medium mb-8 text-lg">Cuéntanos tu caso de uso y revisaremos si Guira puede ayudar a tu empresa a recibir pagos en USD, instruir pagos empresariales B2B vía ACH o Wire, y operar internacionalmente con más claridad y trazabilidad.</p>
              </div>

              <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm space-y-6">
                  <div class="flex gap-4">
                      <i data-lucide="mail" class="w-6 h-6 text-guira-teal"></i>
                      <div>
                          <div class="font-bold text-slate-900">Email comercial</div>
                          <a href="mailto:administracion@guiracorp.com"
                              class="text-sm text-slate-500 hover:text-guira-teal transition-colors font-medium">administracion@guiracorp.com</a>
                      </div>
                  </div>
                  <div class="flex gap-4">
                      <i data-lucide="life-buoy" class="w-6 h-6 text-guira-teal"></i>
                      <div>
                          <div class="font-bold text-slate-900">Asesoría de onboarding</div>
                          <a href="mailto:soporte@guiracorp.com"
                              class="text-sm text-slate-500 hover:text-guira-teal transition-colors font-medium">soporte@guiracorp.com</a>
                      </div>
                  </div>
                  <div class="flex gap-4">
                      <i data-lucide="file-check-2" class="w-6 h-6 text-guira-teal"></i>
                      <div>
                          <div class="font-bold text-slate-900">Consulta sobre elegibilidad</div>
                          <p class="text-sm text-slate-500 font-medium pt-1">Revisaremos la estructura de tu caso de uso B2B.</p>
                      </div>
                  </div>

                  <hr class="border-slate-100">

                  <div class="flex gap-4">
                      <i data-lucide="map-pin" class="w-6 h-6 text-guira-teal"></i>
                      <div>
                          <div class="font-bold text-slate-900">Estados Unidos</div>
                          <p class="text-sm text-slate-500 font-medium pt-1">1201 North Market Street #111, Wilmington, 19801, Delaware</p>
                          <a href="tel:+13057681048" class="text-sm text-slate-500 hover:text-guira-teal transition-colors font-medium block mt-1">+1 305 768 1048</a>
                      </div>
                  </div>

                  <div class="flex gap-4">
                      <i data-lucide="map-pin" class="w-6 h-6 text-guira-teal"></i>
                      <div>
                          <div class="font-bold text-slate-900">Asesores Guira Bolivia</div>
                          <p class="text-sm text-slate-500 font-medium pt-1">Calle 8 de Calacoto #8330, La Paz, Bolivia</p>
                          <a href="https://wa.me/59175245845" target="_blank" rel="noopener noreferrer" class="text-sm text-emerald-600 hover:text-emerald-500 transition-colors font-medium flex items-center gap-1.5 mt-1">
                              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg> 
                          WhatsApp: +591-75245845
                      </a>
                  </div>
              </div>
          </div>
          </div>

          <!-- Form -->
          <div class="md:col-span-3 bg-white p-8 rounded-3xl border border-slate-200 shadow-sm reveal-right">
              <h2 class="text-2xl font-bold text-slate-900 mb-6">Déjanos tu mensaje</h2>
              <form id="contact-form" action="https://api.web3forms.com/submit" method="POST" class="space-y-5">
                  <input type="hidden" name="access_key" value="8707452b-a137-481b-ba1b-75d2b548b4eb">
                  <input type="hidden" name="subject" value="Nuevo mensaje de contacto - Guira Empresas">

                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                      <div class="space-y-1">
                          <label for="name" class="text-xs font-bold text-slate-500 uppercase tracking-wider">Nombre</label>
                          <input type="text" id="name" name="name" required
                              class="w-full px-4 py-3 rounded-xl bg-slate-50 border border-slate-200 focus:bg-white focus:border-guira-teal focus:ring-2 focus:ring-guira-teal/20 transition-all outline-none font-medium text-slate-900 placeholder-slate-400">
                      </div>
                      <div class="space-y-1">
                          <label for="company" class="text-xs font-bold text-slate-500 uppercase tracking-wider">Empresa</label>
                          <input type="text" id="company" name="company" required
                              class="w-full px-4 py-3 rounded-xl bg-slate-50 border border-slate-200 focus:bg-white focus:border-guira-teal focus:ring-2 focus:ring-guira-teal/20 transition-all outline-none font-medium text-slate-900 placeholder-slate-400">
                      </div>
                  </div>

                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                      <div class="space-y-1">
                          <label for="email" class="text-xs font-bold text-slate-500 uppercase tracking-wider">Email Corporativo</label>
                          <input type="email" id="email" name="email" required
                              class="w-full px-4 py-3 rounded-xl bg-slate-50 border border-slate-200 focus:bg-white focus:border-guira-teal focus:ring-2 focus:ring-guira-teal/20 transition-all outline-none font-medium text-slate-900 placeholder-slate-400">
                      </div>
                      <div class="space-y-1">
                          <label for="country" class="text-xs font-bold text-slate-500 uppercase tracking-wider">País</label>
                          <input type="text" id="country" name="country" required
                              class="w-full px-4 py-3 rounded-xl bg-slate-50 border border-slate-200 focus:bg-white focus:border-guira-teal focus:ring-2 focus:ring-guira-teal/20 transition-all outline-none font-medium text-slate-900 placeholder-slate-400">
                      </div>
                  </div>

                  <div class="space-y-1">
                      <label for="topic" class="text-xs font-bold text-slate-500 uppercase tracking-wider">Tipo de Operación</label>
                      <select id="topic" name="topic" required
                          class="w-full px-4 py-3 rounded-xl bg-slate-50 border border-slate-200 focus:bg-white focus:border-guira-teal focus:ring-2 focus:ring-guira-teal/20 transition-all outline-none font-medium text-slate-900">
                          <option value="">Selecciona tu enfoque principal</option>
                          <option value="cobros">Recibir pagos internacionales en USD</option>
                          <option value="pagos">Pagar a proveedores externos</option>
                          <option value="ambos">Cobros y pagos unificados</option>
                          <option value="otro">Otras consultas empresariales</option>
                      </select>
                  </div>

                  <div class="space-y-1">
                      <label for="message" class="text-xs font-bold text-slate-500 uppercase tracking-wider">Mensaje</label>
                      <textarea id="message" name="message" rows="4" required
                          class="w-full px-4 py-3 rounded-xl bg-slate-50 border border-slate-200 focus:bg-white focus:border-guira-teal focus:ring-2 focus:ring-guira-teal/20 transition-all outline-none font-medium text-slate-900 placeholder-slate-400 resize-none"></textarea>
                  </div>

                  <div class="pt-2 pb-4">
                      <label class="flex items-start gap-3 cursor-pointer group">
                          <div class="relative flex items-center justify-center mt-0.5">
                              <input type="checkbox" required
                                  class="peer appearance-none w-5 h-5 border-2 border-slate-300 rounded cursor-pointer checked:bg-guira-teal checked:border-guira-teal transition-colors">
                              <i data-lucide="check"
                                  class="absolute w-3 h-3 text-white opacity-0 peer-checked:opacity-100 pointer-events-none transition-opacity"></i>
                          </div>
                          <span
                              class="text-xs text-slate-500 font-medium leading-relaxed group-hover:text-slate-700 transition-colors">He leído y acepto la <a href="/privacidad" class="text-guira-teal font-bold hover:underline">Política de Privacidad</a> de Guira. Autorizo que Guira se comunique conmigo por correo electrónico, teléfono o WhatsApp para dar seguimiento a mi consulta.</span>
                      </label>
                  </div>

                  <button type="submit"
                      class="w-full py-4 bg-slate-900 text-white rounded-xl font-bold text-lg hover:bg-slate-800 transition-all shadow-md active:scale-[0.98]">Enviar consulta</button>

              </form>
          </div>

      </div>
  </main>

  <script>
      document.getElementById('contact-form').addEventListener('submit', function (e) {
          e.preventDefault();
          const form = this;
          const btn = form.querySelector('button[type="submit"]');
          const originalText = btn.innerText;

          // Comprobar si se ha configurado Formspree u otro servicio
          const action = form.getAttribute('action');
          if (!action || action === '#' || action === '' || action.includes('4bcb5f9d527045acbf8594b2b665542c')) {
              // Comportamiento de demostración por defecto con aviso instructivo
              btn.innerHTML = '<i data-lucide="loader-2" class="w-5 h-5 animate-spin mx-auto"></i>';
              if (typeof lucide !== 'undefined') lucide.createIcons();
              
              setTimeout(() => {
                  btn.innerHTML = '<i data-lucide="check" class="w-5 h-5 mx-auto"></i> ¡Simulado con éxito! (Reemplaza el ID de Formspree en el HTML)';
                  btn.classList.add('bg-emerald-600');
                  btn.classList.remove('bg-slate-900');
                  if (typeof lucide !== 'undefined') lucide.createIcons();

                  setTimeout(() => {
                      btn.innerHTML = originalText;
                      btn.classList.remove('bg-emerald-600');
                      btn.classList.add('bg-slate-900');
                      form.reset();
                  }, 4000);
              }, 1000);
              return;
          }

          // Envío real por AJAX
          btn.disabled = true;
          btn.innerHTML = '<i data-lucide="loader-2" class="w-5 h-5 animate-spin mx-auto"></i> Enviando...';
          if (typeof lucide !== 'undefined') lucide.createIcons();

          fetch(action, {
              method: 'POST',
              body: new FormData(form),
              headers: {
                  'Accept': 'application/json'
              }
          })
          .then(response => response.json())
          .then(data => {
              if (data.success) {
                  const topic = form.querySelector('[name="topic"]')?.value || 'not_selected';
                  window.posthog?.capture('contact_form_submitted', {
                      topic,
                      form_path: window.location.pathname
                  });
                  btn.innerHTML = '<i data-lucide="check" class="w-5 h-5 mx-auto"></i> ¡Mensaje enviado con éxito!';
                  btn.classList.add('bg-emerald-600');
                  btn.classList.remove('bg-slate-900');
                  if (typeof lucide !== 'undefined') lucide.createIcons();
                  form.reset();
              } else {
                  window.posthog?.capture('contact_form_failed', {
                      failure_type: 'api_response',
                      form_path: window.location.pathname
                  });
                  btn.innerHTML = 'Error: ' + (data.message || 'Verifica tu clave de formulario.');
                  btn.classList.add('bg-rose-600');
                  btn.classList.remove('bg-slate-900');
              }
              setTimeout(() => {
                  btn.innerHTML = originalText;
                  btn.classList.remove('bg-emerald-600', 'bg-rose-600');
                  btn.classList.add('bg-slate-900');
                  btn.disabled = false;
              }, 4000);
          })
          .catch(error => {
              window.posthog?.capture('contact_form_failed', {
                  failure_type: 'network_error',
                  form_path: window.location.pathname
              });
              window.posthog?.captureException(error);
              btn.innerHTML = 'Error de conexión.';
              btn.classList.add('bg-rose-600');
              btn.classList.remove('bg-slate-900');
              setTimeout(() => {
                  btn.innerHTML = originalText;
                  btn.classList.remove('bg-rose-600');
                  btn.classList.add('bg-slate-900');
                  btn.disabled = false;
              }, 4000);
          });
      });
  </script>
</Layout>
