---
import Layout from '../layouts/Layout.astro';
import DemoForm from '../components/DemoForm.astro';
import StackedSections from '../components/StackedSections.astro';
---

<Layout
  title="Solicitar Demo para Empresas | Guira Empresas"
  description="Agenda una sesión demostrativa de la plataforma tecnológica de Guira. Diseñada para escalar pagos y operaciones empresariales en la nube."
  keywords="demo plataforma tecnológica, demo guira, cuenta empresarial, contacto B2B plataforma tecnológica"
  canonicalUrl="https://www.guiracorp.com/demo"
  footerTheme="light"
  copyright="Guira Empresas © 2026 Guira System LLC. Representado en Bolivia por Guiraglobal SRL. Todos los derechos reservados."
>
  <Fragment slot="head">
    <!-- Schema: BreadcrumbList -->
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://www.guiracorp.com/"},
        {"@type": "ListItem", "position": 2, "name": "Solicitar Demo", "item": "https://www.guiracorp.com/demo"}
      ]
    }
    </script>
  </Fragment>

  <StackedSections>
  <!-- Main Content -->
  <main data-stack-section class="pt-32 pb-24 flex-1 flex items-center justify-center text-left">
      <div class="max-w-6xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-start">

          <div class="reveal-left">
              <span
                  class="inline-flex py-1 px-3 rounded-full text-xs font-bold bg-guira-teal/10 text-guira-teal mb-6">Ejecutivos B2B Especializados</span>
              <h1 class="text-4xl md:text-5xl font-extrabold text-slate-900 mb-6">Solicita una demo para tu <span class="text-gradient">empresa</span></h1>
              <p class="text-lg text-slate-600 font-medium mb-8">Revisaremos tu caso de uso, la estructura operativa que necesitas y si Guira encaja con tu operación internacional en USD.</p>
              <div class="space-y-6">
                  <div class="flex items-center gap-4">
                      <div
                          class="w-12 h-12 rounded-xl bg-white border border-slate-200 flex items-center justify-center text-slate-700 shadow-sm">
                          <i data-lucide="briefcase" class="w-6 h-6"></i></div>
                      <div>
                          <div class="font-bold text-slate-900">Revisión de encaje operativo</div>
                          <div class="text-sm text-slate-500">Análisis para asegurar que solucionamos tu necesidad.</div>
                      </div>
                  </div>
                  <div class="flex items-center gap-4">
                      <div
                          class="w-12 h-12 rounded-xl bg-white border border-slate-200 flex items-center justify-center text-slate-700 shadow-sm">
                          <i data-lucide="layout-dashboard" class="w-6 h-6"></i></div>
                      <div>
                          <div class="font-bold text-slate-900">Recorrido por la plataforma</div>
                          <div class="text-sm text-slate-500">Demostración del panel de gestión y pagos.</div>
                      </div>
                  </div>
                  <div class="flex items-center gap-4">
                      <div
                          class="w-12 h-12 rounded-xl bg-white border border-slate-200 flex items-center justify-center text-slate-700 shadow-sm">
                          <i data-lucide="file-check-2" class="w-6 h-6"></i></div>
                      <div>
                          <div class="font-bold text-slate-900">Requisitos de validación empresarial</div>
                          <div class="text-sm text-slate-500">Revisión de estructura documental exigida.</div>
                      </div>
                  </div>
              </div>
          </div>

          <DemoForm />

      </div>
  </main>
  </StackedSections>
</Layout>
