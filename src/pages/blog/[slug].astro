---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { render } from 'astro:content';

const getSlug = (id: string) => id.replace(/\.md$/, '');

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter(p => p.id !== post.id && p.data.category === post.data.category)
  .slice(0, 2);

const formatDate = (date: Date) => {
  return date.toLocaleDateString('es-BO', { year: 'numeric', month: 'long', day: 'numeric' });
};

const categoryColors: Record<string, string> = {
  'Pagos Internacionales': 'bg-blue-50 text-blue-700 border-blue-200',
  'Gestión de Proveedores': 'bg-emerald-50 text-emerald-700 border-emerald-200',
  'Seguridad Financiera': 'bg-violet-50 text-violet-700 border-violet-200',
};
const getCategoryClass = (cat: string) => categoryColors[cat] ?? 'bg-slate-50 text-slate-700 border-slate-200';

const categoryIcons: Record<string, string> = {
  'Pagos Internacionales': 'arrow-right-left',
  'Gestión de Proveedores': 'building-2',
  'Seguridad Financiera': 'shield-check',
};
const getCategoryIcon = (cat: string) => categoryIcons[cat] ?? 'file-text';

const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
const canonicalUrl = `https://www.guiracorp.com/blog/${getSlug(post.id)}`;
---

<Layout
  title={`${post.data.title} | Blog Guira Empresas`}
  description={post.data.description}
  keywords={post.data.keywords}
  canonicalUrl={canonicalUrl}
  ogTitle={post.data.title}
  ogDescription={post.data.description}
  footerTheme="rich-dark"
>
  <slot name="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": post.data.title,
      "description": post.data.description,
      "datePublished": post.data.pubDate.toISOString(),
      "dateModified": (post.data.updatedDate ?? post.data.pubDate).toISOString(),
      "author": {
        "@type": "Organization",
        "name": post.data.author,
        "url": "https://www.guiracorp.com"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Guira System LLC",
        "url": "https://www.guiracorp.com",
        "logo": { "@type": "ImageObject", "url": "https://www.guiracorp.com/guira-logo.svg" }
      },
      "mainEntityOfPage": { "@type": "WebPage", "@id": canonicalUrl },
      "keywords": post.data.keywords
    })} />
  </slot>

  <!-- Reading Progress Bar -->
  <div id="reading-progress" class="fixed top-0 left-0 h-0.5 bg-gradient-to-r from-guira-teal to-guira-cyan z-[60] transition-all duration-100" style="width: 0%"></div>

  <!-- Breadcrumb -->
  <div class="pt-24 pb-0 border-b border-slate-100 bg-slate-50/60">
    <div class="max-w-7xl mx-auto px-6 py-3">
      <nav class="flex items-center gap-2 text-xs font-medium text-slate-500" aria-label="Breadcrumb">
        <a href="/" class="hover:text-slate-800 transition-colors">Inicio</a>
        <i data-lucide="chevron-right" class="w-3.5 h-3.5 text-slate-300"></i>
        <a href="/blog" class="hover:text-slate-800 transition-colors">Blog</a>
        <i data-lucide="chevron-right" class="w-3.5 h-3.5 text-slate-300"></i>
        <span class="text-slate-700 truncate max-w-[200px] md:max-w-sm">{post.data.title}</span>
      </nav>
    </div>
  </div>

  <!-- Article Header -->
  <header class="bg-slate-50/60 border-b border-slate-100">
    <div class="max-w-7xl mx-auto px-6 py-12 md:py-16">
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-3 mb-5">
          <span class={`inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold border ${getCategoryClass(post.data.category)}`}>
            <i data-lucide={getCategoryIcon(post.data.category)} class="w-3 h-3"></i>
            {post.data.category}
          </span>
          <span class="text-slate-300">·</span>
          <span class="flex items-center gap-1.5 text-xs text-slate-500 font-medium">
            <i data-lucide="clock" class="w-3.5 h-3.5"></i>
            {post.data.readingTime} min de lectura
          </span>
          <span class="text-slate-300">·</span>
          <span class="flex items-center gap-1.5 text-xs text-slate-500 font-medium">
            <i data-lucide="calendar" class="w-3.5 h-3.5"></i>
            {formatDate(post.data.pubDate)}
          </span>
        </div>

        <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-slate-900 leading-tight mb-5">
          {post.data.title}
        </h1>

        <p class="text-lg text-slate-600 leading-relaxed mb-6">
          {post.data.description}
        </p>

        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-guira-teal/10 border border-guira-teal/20 flex items-center justify-center">
            <i data-lucide="user" class="w-5 h-5 text-guira-teal"></i>
          </div>
          <div>
            <div class="text-sm font-bold text-slate-800">{post.data.author}</div>
            <div class="text-xs text-slate-500">{post.data.authorRole}</div>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- Main Content Layout -->
  <div class="max-w-7xl mx-auto px-6 py-12">
    <div class="flex gap-12 items-start">

      <!-- Article Body -->
      <article class="flex-1 min-w-0 max-w-3xl">
        <!-- Table of Contents (mobile only) -->
        {tocHeadings.length > 0 && (
          <div class="lg:hidden mb-8 rounded-xl border border-slate-200 bg-slate-50 overflow-hidden">
            <button id="toc-toggle-mobile" class="w-full flex items-center justify-between gap-3 p-4 text-sm font-bold text-slate-700" aria-expanded="false">
              <span class="flex items-center gap-2">
                <i data-lucide="list" class="w-4 h-4 text-guira-teal"></i>
                Índice del artículo
              </span>
              <i data-lucide="chevron-down" class="w-4 h-4 text-slate-400 transition-transform" id="toc-chevron"></i>
            </button>
            <nav id="toc-mobile-content" class="hidden px-4 pb-4">
              <ul class="space-y-1.5">
                {tocHeadings.map(h => (
                  <li style={h.depth === 3 ? 'padding-left: 1rem' : ''}>
                    <a
                      href={`#${h.slug}`}
                      class="flex items-center gap-2 py-1 text-sm text-slate-600 hover:text-guira-teal transition-colors group"
                    >
                      <span class={`inline-block shrink-0 rounded-full bg-slate-200 group-hover:bg-guira-teal/20 transition-colors ${h.depth === 2 ? 'w-1.5 h-1.5' : 'w-1 h-1'}`}></span>
                      {h.text}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </div>
        )}

        <!-- Article prose -->
        <div class="prose-guira">
          <Content />
        </div>

        <!-- Tags -->
        <div class="mt-10 pt-8 border-t border-slate-200">
          <div class="flex flex-wrap items-center gap-2">
            <span class="text-xs font-bold text-slate-500 uppercase tracking-wider">Etiquetas:</span>
            {post.data.tags.map(tag => (
              <span class="text-xs font-medium text-slate-600 bg-slate-100 hover:bg-slate-200 px-3 py-1.5 rounded-full transition-colors">
                #{tag}
              </span>
            ))}
          </div>
        </div>

        <!-- Share -->
        <div class="mt-8 pt-6 border-t border-slate-100">
          <div class="flex flex-wrap items-center gap-3">
            <span class="text-sm font-bold text-slate-700">Compartir:</span>
            <a
              href={`https://wa.me/?text=${encodeURIComponent(post.data.title + ' - ' + canonicalUrl)}`}
              target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-emerald-50 border border-emerald-200 text-emerald-700 text-sm font-semibold hover:bg-emerald-100 transition-colors"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              WhatsApp
            </a>
            <a
              href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(canonicalUrl)}`}
              target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-50 border border-blue-200 text-blue-700 text-sm font-semibold hover:bg-blue-100 transition-colors"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              LinkedIn
            </a>
            <a
              href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(canonicalUrl)}`}
              target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-slate-100 border border-slate-200 text-slate-700 text-sm font-semibold hover:bg-slate-200 transition-colors"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              X (Twitter)
            </a>
          </div>
        </div>

        <!-- Author bio -->
        <div class="mt-10 p-6 rounded-2xl bg-slate-50 border border-slate-200 flex items-start gap-4">
          <div class="w-14 h-14 rounded-2xl bg-guira-teal/10 border border-guira-teal/20 flex items-center justify-center shrink-0">
            <i data-lucide="users" class="w-6 h-6 text-guira-teal"></i>
          </div>
          <div>
            <div class="text-sm font-extrabold text-slate-900 mb-1">{post.data.author}</div>
            <div class="text-xs text-guira-teal font-semibold mb-2">{post.data.authorRole}</div>
            <p class="text-sm text-slate-600 leading-relaxed">
              El equipo de Guira está compuesto por especialistas en finanzas corporativas, compliance y tecnología financiera con experiencia en mercados latinoamericanos. Nuestro objetivo es simplificar las operaciones financieras internacionales para empresas en Bolivia y la región.
            </p>
          </div>
        </div>

        <!-- Related posts -->
        {relatedPosts.length > 0 && (
          <div class="mt-12">
            <h2 class="text-xl font-extrabold text-slate-900 mb-6 flex items-center gap-2">
              <i data-lucide="layers" class="w-5 h-5 text-guira-teal"></i>
              Artículos relacionados
            </h2>
            <div class="grid sm:grid-cols-2 gap-4">
              {relatedPosts.map(related => (
                <a href={`/blog/${getSlug(related.id)}`} class="group block rounded-xl border border-slate-200 p-5 hover:border-guira-teal/30 hover:shadow-md transition-all">
                  <span class={`inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-bold border mb-3 ${getCategoryClass(related.data.category)}`}>
                    {related.data.category}
                  </span>
                  <h3 class="text-sm font-bold text-slate-800 group-hover:text-guira-teal transition-colors leading-snug mb-2">
                    {related.data.title}
                  </h3>
                  <span class="text-xs text-guira-teal font-semibold flex items-center gap-1 group-hover:gap-2 transition-all">
                    Leer <i data-lucide="arrow-right" class="w-3 h-3"></i>
                  </span>
                </a>
              ))}
            </div>
          </div>
        )}
      </article>

      <!-- Sidebar (desktop only) -->
      <aside class="hidden lg:flex flex-col gap-6 w-72 shrink-0">
        <div class="sticky top-24 flex flex-col gap-6">

          <!-- Table of Contents -->
          {tocHeadings.length > 0 && (
            <div class="rounded-xl border border-slate-200 overflow-hidden">
              <div class="px-4 py-3 bg-slate-50 border-b border-slate-200 flex items-center gap-2">
                <i data-lucide="list" class="w-4 h-4 text-guira-teal"></i>
                <span class="text-xs font-bold text-slate-700 uppercase tracking-wider">Índice</span>
              </div>
              <nav class="p-4" id="toc-desktop">
                <ul class="space-y-1.5">
                  {tocHeadings.map(h => (
                    <li style={h.depth === 3 ? 'padding-left: 0.875rem' : ''}>
                      <a
                        href={`#${h.slug}`}
                        data-toc-item={h.slug}
                        class="flex items-start gap-2 py-1 text-xs text-slate-500 hover:text-guira-teal transition-colors group toc-link"
                      >
                        <span class={`inline-block shrink-0 mt-1.5 rounded-full bg-slate-200 group-hover:bg-guira-teal transition-colors ${h.depth === 2 ? 'w-1.5 h-1.5' : 'w-1 h-1'}`}></span>
                        {h.text}
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
            </div>
          )}

          <!-- Share sidebar -->
          <div class="rounded-xl border border-slate-200 overflow-hidden">
            <div class="px-4 py-3 bg-slate-50 border-b border-slate-200 flex items-center gap-2">
              <i data-lucide="share-2" class="w-4 h-4 text-guira-teal"></i>
              <span class="text-xs font-bold text-slate-700 uppercase tracking-wider">Compartir</span>
            </div>
            <div class="p-4 flex flex-col gap-2">
              <a
                href={`https://wa.me/?text=${encodeURIComponent(post.data.title + ' - ' + canonicalUrl)}`}
                target="_blank" rel="noopener noreferrer"
                class="flex items-center gap-2.5 px-3 py-2.5 rounded-lg bg-emerald-50 border border-emerald-100 text-emerald-700 text-xs font-semibold hover:bg-emerald-100 transition-colors"
              >
                <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                WhatsApp
              </a>
              <a
                href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(canonicalUrl)}`}
                target="_blank" rel="noopener noreferrer"
                class="flex items-center gap-2.5 px-3 py-2.5 rounded-lg bg-blue-50 border border-blue-100 text-blue-700 text-xs font-semibold hover:bg-blue-100 transition-colors"
              >
                <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                LinkedIn
              </a>
              <a
                href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(canonicalUrl)}`}
                target="_blank" rel="noopener noreferrer"
                class="flex items-center gap-2.5 px-3 py-2.5 rounded-lg bg-slate-50 border border-slate-200 text-slate-700 text-xs font-semibold hover:bg-slate-100 transition-colors"
              >
                <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                X (Twitter)
              </a>
            </div>
          </div>

          <!-- Sidebar CTA -->
          <div class="rounded-xl bg-gradient-to-br from-guira-petrol to-guira-dark p-5 relative overflow-hidden">
            <div class="fintech-orb w-24 h-24 bg-guira-teal -top-8 -right-8 opacity-25"></div>
            <div class="relative z-10">
              <div class="w-9 h-9 rounded-lg bg-white/10 flex items-center justify-center mb-3">
                <i data-lucide="zap" class="w-4 h-4 text-white/80"></i>
              </div>
              <h3 class="text-white font-extrabold text-sm mb-2 leading-snug">Simplifica tus pagos internacionales</h3>
              <p class="text-slate-400 text-xs leading-relaxed mb-4">Guira centraliza todo: pagos a proveedores, recepción en USD y validación B2B.</p>
              <a href="/demo" class="block text-center bg-white text-slate-900 text-xs font-bold px-4 py-2.5 rounded-lg hover:bg-slate-100 transition-colors">
                Solicitar Demo Gratis
              </a>
            </div>
          </div>

        </div>
      </aside>

    </div>
  </div>

  <!-- Bottom CTA -->
  <section class="border-t border-slate-100 bg-slate-50 py-16">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-guira-teal/10 border border-guira-teal/20 text-guira-teal text-xs font-bold mb-4">
        <i data-lucide="rocket" class="w-3.5 h-3.5"></i>
        ¿Te resultó útil este artículo?
      </div>
      <h2 class="text-2xl md:text-3xl font-extrabold text-slate-900 mb-4">
        Guira resuelve exactamente<br class="hidden md:block" /> lo que acabas de leer
      </h2>
      <p class="text-slate-600 mb-8 max-w-xl mx-auto">
        Nuestra plataforma fue construida para empresas bolivianas y latinoamericanas que necesitan operar internacionalmente sin la complejidad del sistema bancario tradicional.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/demo" class="btn-primary gap-2">
          <i data-lucide="calendar" class="w-4 h-4"></i>
          Solicitar Demo Gratuita
        </a>
        <a href="/producto" class="btn-secondary gap-2">
          <i data-lucide="arrow-right" class="w-4 h-4"></i>
          Ver cómo funciona
        </a>
      </div>
    </div>
  </section>

</Layout>

<script>
  // Reading Progress Bar
  const progressBar = document.getElementById('reading-progress');
  const article = document.querySelector('.prose-guira');

  if (progressBar && article) {
    const updateProgress = () => {
      const rect = article.getBoundingClientRect();
      const articleHeight = article.scrollHeight;
      const scrolled = -rect.top;
      const total = articleHeight - window.innerHeight;
      const progress = Math.min(Math.max((scrolled / total) * 100, 0), 100);
      progressBar.style.width = progress + '%';
    };
    window.addEventListener('scroll', updateProgress, { passive: true });
    updateProgress();
  }

  // TOC Mobile Toggle
  const tocToggle = document.getElementById('toc-toggle-mobile');
  const tocContent = document.getElementById('toc-mobile-content');
  const tocChevron = document.getElementById('toc-chevron');

  if (tocToggle && tocContent && tocChevron) {
    tocToggle.addEventListener('click', () => {
      const isOpen = !tocContent.classList.contains('hidden');
      tocContent.classList.toggle('hidden', isOpen);
      tocChevron.style.transform = isOpen ? 'rotate(0deg)' : 'rotate(180deg)';
      tocToggle.setAttribute('aria-expanded', String(!isOpen));
    });
  }

  // TOC Active Highlight
  const tocLinks = document.querySelectorAll('.toc-link');
  const headingElements: Element[] = [];

  tocLinks.forEach(link => {
    const href = link.getAttribute('href');
    if (href) {
      const id = href.replace('#', '');
      const el = document.getElementById(id);
      if (el) headingElements.push(el);
    }
  });

  const highlightToc = () => {
    let current = '';
    headingElements.forEach(el => {
      if (el.getBoundingClientRect().top <= 120) {
        current = el.id;
      }
    });

    tocLinks.forEach(link => {
      const href = link.getAttribute('href');
      const id = href ? href.replace('#', '') : '';
      const dot = link.querySelector('span');
      if (id === current) {
        link.classList.add('text-guira-teal', 'font-semibold');
        link.classList.remove('text-slate-500');
        if (dot) { dot.classList.add('bg-guira-teal'); dot.classList.remove('bg-slate-200'); }
      } else {
        link.classList.remove('text-guira-teal', 'font-semibold');
        link.classList.add('text-slate-500');
        if (dot) { dot.classList.remove('bg-guira-teal'); dot.classList.add('bg-slate-200'); }
      }
    });
  };

  window.addEventListener('scroll', highlightToc, { passive: true });
  highlightToc();

  // Smooth scroll for TOC links
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', (e) => {
      e.preventDefault();
      const href = anchor.getAttribute('href');
      if (!href) return;
      const target = document.querySelector(href);
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        history.pushState(null, '', href);
      }
    });
  });
</script>
