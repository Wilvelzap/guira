---
import Layout from '../layouts/Layout.astro';
import StackedSections from '../components/StackedSections.astro';
---

<Layout
  title="Página no encontrada (404) | Guira Empresas"
  description="La página que estás buscando no existe o ha sido movida. Vuelve al inicio o explora nuestros servicios transfronterizos B2B."
  robots="noindex, follow"
>
  <StackedSections>
    <div data-stack-section class="min-h-[70vh] flex items-center justify-center py-20 px-6">
    <div class="max-w-md w-full text-center">
      <div class="inline-flex items-center justify-center w-20 h-20 bg-slate-100 rounded-2xl mb-6 text-slate-800 text-3xl font-extrabold shadow-inner border border-slate-200">
        404
      </div>
      <h1 class="text-3xl font-black text-slate-900 tracking-tight mb-3">Página no encontrada</h1>
      <p class="text-slate-600 text-sm leading-relaxed mb-8">
        La dirección a la que intentas acceder no existe, ha cambiado de ubicación o fue movida.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/" class="px-6 py-3 bg-slate-900 text-white font-bold rounded-xl text-sm hover:bg-slate-800 transition-all shadow-md">
          Ir a Inicio
        </a>
        <a href="/faq" class="px-6 py-3 bg-white text-slate-700 font-bold rounded-xl text-sm border border-slate-200 hover:bg-slate-50 transition-all">
          Preguntas Frecuentes
        </a>
      </div>
    </div>
  </div>
  </StackedSections>
</Layout>
