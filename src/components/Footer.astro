---
interface Props {
  theme?: 'dark' | 'light' | 'rich-dark';
}

const { theme = 'light' } = Astro.props;
---

{theme === 'rich-dark' ? (
  <footer class="border-t border-white/10 bg-guira-dark pt-20 pb-10 mt-auto text-left">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-10 mb-16">
        <div class="col-span-2 md:col-span-1">
          <a href="/" class="flex items-center gap-2 mb-6">
            <img src="/guira-logo.svg" alt="Guira Logo - Finanzas corporativas" class="h-6 object-contain invert brightness-0" />
            <span class="text-white font-extrabold text-lg">Guira Empresas</span>
          </a>
          <p class="text-sm text-slate-400 font-medium mb-6">Infraestructura financiera corporativa para consolidar pagos, gestión operativa y recepciones B2B en las Américas.</p>
        </div>

        <div>
          <h3 class="text-white font-bold mb-4">Soluciones</h3>
          <ul class="space-y-3 text-sm font-medium text-slate-400">
            <li><a href="/producto" class="hover:text-white transition-colors">Recepción en USD</a></li>
            <li><a href="/producto" class="hover:text-white transition-colors">Enrutamiento Operativo</a></li>
            <li><a href="/producto" class="hover:text-white transition-colors">Pagos a Proveedores B2B</a></li>
            <li><a href="/soluciones" class="hover:text-white transition-colors">Para Agencias y Exportadores</a></li>
          </ul>
        </div>

        <div>
          <h3 class="text-white font-bold mb-4">Empresa y Plataforma</h3>
          <ul class="space-y-3 text-sm font-medium text-slate-400">
            <li><a href="/sobre-guira" class="hover:text-white transition-colors">Acerca de Guira</a></li>
            <li><a href="/como-funciona" class="hover:text-white transition-colors">El proceso paso a paso</a></li>
            <li><a href="/seguridad" class="hover:text-white transition-colors">Protocolos de Compliance</a></li>
            <li><a href="/blog" class="hover:text-white transition-colors">Blog y Recursos</a></li>
            <li><a href="/contacto" class="hover:text-white transition-colors">Contacto Corporativo</a></li>
          </ul>
        </div>

        <div>
          <h3 class="text-white font-bold mb-4">Legal</h3>
          <ul class="space-y-3 text-sm font-medium text-slate-400">
            <li><a href="/terminos" class="hover:text-white transition-colors">Condiciones Generales</a></li>
            <li><a href="/privacidad" class="hover:text-white transition-colors">Protección de Datos</a></li>
            <li><a href="/cookies" class="hover:text-white transition-colors">Política de Cookies</a></li>
            <li><a href="/faq" class="hover:text-white transition-colors">Preguntas Frecuentes / FAQ</a></li>
          </ul>
        </div>
      </div>

      <div class="border-t border-white/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-xs font-semibold text-slate-500">© 2026 Guira System LLC. Todos los derechos comerciales reservados.</p>
        <p class="text-xs font-medium text-slate-500 max-w-xl text-center md:text-right">Guira es una plataforma tecnológica B2B. No somos banco, entidad financiera, casa de cambio, billetera de consumo ni custodio directo de fondos. Los servicios financieros, rieles de pago, cuentas de recepción, custodia, movimiento de fondos o procesamiento transaccional, cuando correspondan, son provistos exclusivamente por terceros o partners aplicables bajo sus propias autorizaciones, términos, límites, jurisdicciones y criterios de aprobación. La disponibilidad del servicio depende del perfil de la empresa, documentación presentada, jurisdicción, caso de uso y revisión correspondiente.</p>
      </div>
    </div>
  </footer>
) : theme === 'dark' ? (
  <footer class="border-t border-white/10 bg-guira-dark pt-12 pb-8 mt-auto text-left">
    <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-6">
      <div class="flex items-center gap-2">
        <img src="/guira-logo.svg" alt="Guira Logo" class="h-6 object-contain invert brightness-0" />
        <span class="text-white font-bold text-sm">Guira Empresas</span>
      </div>
      <div class="flex flex-wrap justify-center gap-6 text-xs text-slate-500 font-medium">
        <a href="/producto" class="hover:text-white transition-colors">Producto</a>
        <a href="/soluciones" class="hover:text-white transition-colors">Soluciones</a>
        <a href="/como-funciona" class="hover:text-white transition-colors">Cómo funciona</a>
        <a href="/terminos" class="hover:text-white transition-colors">Términos</a>
        <a href="/privacidad" class="hover:text-white transition-colors">Privacidad</a>
        <a href="/cookies" class="hover:text-white transition-colors">Cookies</a>
      </div>
      <p class="text-xs text-slate-400 font-medium">© 2026 Guira System LLC. Todos los derechos reservados.</p>
    </div>
    <div class="max-w-7xl mx-auto px-6 mt-8">
      <p class="text-[10px] text-slate-500 leading-relaxed text-center">
        Guira es una plataforma tecnológica B2B. No somos banco, entidad financiera, casa de cambio, billetera de consumo ni custodio directo de fondos. Los servicios financieros, rieles de pago, cuentas de recepción, custodia, movimiento de fondos o procesamiento transaccional, cuando correspondan, son provistos exclusivamente por terceros o partners aplicables bajo sus propias autorizaciones, términos, límites, jurisdicciones y criterios de aprobación. La disponibilidad del servicio depende del perfil de la empresa, documentación presentada, jurisdicción, caso de uso y revisión correspondiente.
      </p>
    </div>
  </footer>
) : (
  <footer class="border-t border-slate-200 bg-white pt-10 pb-10 mt-auto text-left">
    <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-4 text-xs font-semibold text-slate-500">
      <div class="flex items-center gap-2">
        <img src="/guira-logo.svg" alt="Guira Logo" class="h-6 object-contain" />
        <span class="text-slate-900 font-bold">Guira Empresas</span>
      </div>
      <p>© 2026 Guira System LLC. Todos los derechos reservados.</p>
    </div>
    <div class="max-w-7xl mx-auto px-6 mt-4">
      <p class="text-[10px] text-slate-400 leading-relaxed text-center">
        Guira es una plataforma tecnológica B2B. No somos banco, entidad financiera, casa de cambio, billetera de consumo ni custodio directo de fondos. Los servicios financieros, rieles de pago, cuentas de recepción, custodia, movimiento de fondos o procesamiento transaccional, cuando correspondan, son provistos exclusivamente por terceros o partners aplicables bajo sus propias autorizaciones, términos, límites, jurisdicciones y criterios de aprobación. La disponibilidad del servicio depende del perfil de la empresa, documentación presentada, jurisdicción, caso de uso y revisión correspondiente.
      </p>
    </div>
  </footer>
)}
