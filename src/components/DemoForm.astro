---
// DemoForm.astro - Componente compartido de formulario de demo
// Usado en: /demo (página independiente) y /pagos-cobros-internacionales (embebido)
---

<div
    class="bg-white rounded-3xl border border-slate-200 shadow-[0_20px_50px_-12px_rgba(0,0,0,0.1)] p-8 md:p-10 reveal-right relative z-10">
    <h2 class="text-2xl font-bold text-slate-900 mb-2">Ingresa tus datos corporativos</h2>
    <p class="text-sm text-slate-500 mb-8">Un especialista se comunicará a la brevedad.</p>

    <form id="demo-form" action="https://api.web3forms.com/submit" method="POST" class="space-y-5">
        <input type="hidden" name="access_key" value="8707452b-a137-481b-ba1b-75d2b548b4eb">
        <input type="hidden" name="subject" value="Nueva solicitud de demo - Guira Empresas">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="space-y-1">
                <label for="fname" class="text-xs font-bold text-slate-500 uppercase tracking-wider">Nombre</label>
                <input type="text" id="fname" name="first_name" required
                    class="w-full px-4 py-3 rounded-xl bg-slate-50 border border-slate-200 focus:bg-white focus:border-guira-teal focus:ring-2 focus:ring-guira-teal/20 transition-all outline-none font-medium text-slate-900 placeholder-slate-400"
                    placeholder="Juan">
            </div>
            <div class="space-y-1">
                <label for="lname" class="text-xs font-bold text-slate-500 uppercase tracking-wider">Apellido</label>
                <input type="text" id="lname" name="last_name" required
                    class="w-full px-4 py-3 rounded-xl bg-slate-50 border border-slate-200 focus:bg-white focus:border-guira-teal focus:ring-2 focus:ring-guira-teal/20 transition-all outline-none font-medium text-slate-900 placeholder-slate-400"
                    placeholder="Pérez">
            </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="space-y-1">
                <label for="email" class="text-xs font-bold text-slate-500 uppercase tracking-wider">Email Corporativo</label>
                <input type="email" id="email" name="email" required
                    class="w-full px-4 py-3 rounded-xl bg-slate-50 border border-slate-200 focus:bg-white focus:border-guira-teal focus:ring-2 focus:ring-guira-teal/20 transition-all outline-none font-medium text-slate-900 placeholder-slate-400"
                    placeholder="juan@tuempresa.com">
            </div>
            <div class="space-y-1">
                <label for="company" class="text-xs font-bold text-slate-500 uppercase tracking-wider">Empresa</label>
                <input type="text" id="company" name="company" required
                    class="w-full px-4 py-3 rounded-xl bg-slate-50 border border-slate-200 focus:bg-white focus:border-guira-teal focus:ring-2 focus:ring-guira-teal/20 transition-all outline-none font-medium text-slate-900 placeholder-slate-400"
                    placeholder="Empresa Tech LLC">
            </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="space-y-1">
                <label for="volume" class="text-xs font-bold text-slate-500 uppercase tracking-wider">Volumen Estimado USD</label>
                <select id="volume" name="volume"
                    class="w-full px-4 py-3 rounded-xl bg-slate-50 border border-slate-200 focus:bg-white focus:border-guira-teal focus:ring-2 focus:ring-guira-teal/20 transition-all outline-none font-medium text-slate-900">
                    <option value="">Selecciona volumen</option>
                    <option value="menos-10k">Menos de $10k / mes</option>
                    <option value="10k-50k">$10k - $50k / mes</option>
                    <option value="50k-500k">$50k - $500k / mes</option>
                    <option value="500k+">Más de $500k</option>
                </select>
            </div>
            <div class="space-y-1">
                <label for="usecase" class="text-xs font-bold text-slate-500 uppercase tracking-wider">Caso de Uso Principal</label>
                <select id="usecase" name="usecase"
                    class="w-full px-4 py-3 rounded-xl bg-slate-50 border border-slate-200 focus:bg-white focus:border-guira-teal focus:ring-2 focus:ring-guira-teal/20 transition-all outline-none font-medium text-slate-900">
                    <option value="">Selecciona caso</option>
                    <option value="cobros">Cobros internacionales</option>
                    <option value="pagos">Pago a proveedores</option>
                    <option value="ambos">Cobros y pagos unificados</option>
                </select>
            </div>
        </div>

        <div class="pt-2 pb-4">
            <label class="flex items-start gap-3 cursor-pointer group">
                <div class="relative flex items-center justify-center mt-0.5">
                    <input type="checkbox" required
                        class="peer appearance-none w-5 h-5 border-2 border-slate-300 rounded cursor-pointer checked:bg-guira-teal checked:border-guira-teal transition-colors">
                    <i data-lucide="check"
                        class="absolute w-3 h-3 text-white opacity-0 peer-checked:opacity-100 pointer-events-none transition-opacity"></i>
                </div>
                <span
                    class="text-xs text-slate-500 font-medium leading-relaxed group-hover:text-slate-700 transition-colors">He
                    leído la <a href="/privacidad"
                        class="text-guira-teal font-bold hover:underline">Política de Privacidad</a> de Guira.</span>
            </label>
        </div>

        <button type="submit"
            class="w-full py-4 bg-slate-900 text-white rounded-xl font-bold text-lg hover:bg-slate-800 transition-all shadow-md active:scale-[0.98]">Solicitar demo</button>

        <p class="text-center text-xs text-slate-400 font-medium pt-2">Toda la información viaja sobre HTTPS
            seguro y es estrictamente comercial.</p>
    </form>
</div>

<script>
    document.getElementById('demo-form').addEventListener('submit', function (e) {
        e.preventDefault();
        const form = this;
        const btn = form.querySelector('button[type="submit"]');
        const originalText = btn.innerText;

        btn.disabled = true;
        btn.innerHTML = '<i data-lucide="loader-2" class="w-5 h-5 animate-spin mx-auto"></i> Enviando...';
        if (typeof lucide !== 'undefined') lucide.createIcons();

        fetch(form.action, {
            method: 'POST',
            body: new FormData(form),
            headers: {
                'Accept': 'application/json'
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                const volume = form.querySelector('[name="volume"]')?.value || 'not_selected';
                const useCase = form.querySelector('[name="usecase"]')?.value || 'not_selected';
                window.posthog?.capture('demo_form_submitted', {
                    volume_range: volume,
                    use_case: useCase,
                    form_path: window.location.pathname
                });
                btn.innerHTML = '<i data-lucide="check" class="w-5 h-5 mx-auto"></i> ¡Mensaje enviado con éxito!';
                btn.classList.add('bg-emerald-600');
                btn.classList.remove('bg-slate-900');
                if (typeof lucide !== 'undefined') lucide.createIcons();
                form.reset();

                window.dataLayer = window.dataLayer || [];
                window.dataLayer.push({
                  'event': 'generate_lead',
                  'lead_type': 'demo_request'
                });
            } else {
                window.posthog?.capture('demo_form_failed', {
                    failure_type: 'api_response',
                    form_path: window.location.pathname
                });
                btn.innerHTML = 'Error: ' + (data.message || 'Verifica tu clave de formulario.');
                btn.classList.add('bg-rose-600');
                btn.classList.remove('bg-slate-900');
            }
            setTimeout(() => {
                btn.innerHTML = originalText;
                btn.classList.remove('bg-emerald-600', 'bg-rose-600');
                btn.classList.add('bg-slate-900');
                btn.disabled = false;
            }, 4000);
        })
        .catch(error => {
            window.posthog?.capture('demo_form_failed', {
                failure_type: 'network_error',
                form_path: window.location.pathname
            });
            window.posthog?.captureException(error);
            btn.innerHTML = 'Error de conexión.';
            btn.classList.add('bg-rose-600');
            btn.classList.remove('bg-slate-900');
            setTimeout(() => {
                btn.innerHTML = originalText;
                btn.classList.remove('bg-rose-600');
                btn.classList.add('bg-slate-900');
                btn.disabled = false;
            }, 4000);
        });
    });
</script>
