---
// Component for Cookie Consent Banner
---

<div id="cookie-banner" class="fixed bottom-6 left-6 right-6 md:left-auto md:max-w-lg bg-slate-900/95 backdrop-blur-md text-slate-200 p-5 md:p-6 rounded-2xl shadow-2xl border border-slate-800/80 z-[100] flex flex-col gap-4 hidden transform translate-y-6 opacity-0 transition-all duration-500 ease-out">
  <div class="flex items-start gap-3 text-left">
    <div class="bg-blue-500/10 p-2.5 rounded-xl border border-blue-500/20 text-blue-400 mt-0.5 shrink-0">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-cookie"><path d="M12 2a10 10 0 1 0 10 10 4 4 0 0 1-5-5 4 4 0 0 1-5-5"/><path d="M8.5 8.5v.01"/><path d="M16 15.5v.01"/><path d="M12 12v.01"/><path d="M11 17v.01"/><path d="M7 14v.01"/></svg>
    </div>
    <div class="space-y-1">
      <h3 class="font-bold text-white text-sm md:text-base">Consentimiento de Cookies</h3>
      <p class="text-xs md:text-sm text-slate-400 leading-relaxed">
        Este sitio utiliza cookies y tecnologías similares para medir el rendimiento de nuestras campañas y mejorar tu experiencia. Al hacer clic en "Aceptar", consientes su uso. Puedes configurar tus preferencias en cualquier momento. Conoce más en nuestra <a href="/cookies" class="text-blue-400 hover:text-blue-300 font-semibold hover:underline">Política de Cookies</a> y <a href="/privacidad" class="text-blue-400 hover:text-blue-300 font-semibold hover:underline">Política de Privacidad</a>.
      </p>
    </div>
  </div>
  <div class="flex gap-3 justify-end items-center">
    <button id="btn-cookie-decline" class="px-4 py-2 text-xs md:text-sm font-semibold rounded-xl text-slate-400 hover:text-white hover:bg-slate-800 transition-all border border-transparent hover:border-slate-700">
      Rechazar
    </button>
    <button id="btn-cookie-accept" class="px-5 py-2 text-xs md:text-sm font-bold bg-blue-600 hover:bg-blue-500 text-white rounded-xl shadow-md transition-all active:scale-[0.97]">
      Aceptar
    </button>
  </div>
</div>

<script is:inline>
  (function() {
    function getCookie(name) {
      let matches = document.cookie.match(new RegExp(
        "(?:^|; )" + name.replace(/([\.$?*|{}\(\)\[\]\\\/\+^])/g, '\\$1') + "=([^;]*)"
      ));
      return matches ? decodeURIComponent(matches[1]) : undefined;
    }

    function setCookie(name, value, days) {
      let expires = "";
      if (days) {
        let date = new Date();
        date.setTime(date.getTime() + (days * 24 * 60 * 60 * 1000));
        expires = "; expires=" + date.toUTCString();
      }
      document.cookie = name + "=" + (value || "") + expires + "; path=/; SameSite=Lax";
    }

    const banner = document.getElementById('cookie-banner');
    const acceptBtn = document.getElementById('btn-cookie-accept');
    const declineBtn = document.getElementById('btn-cookie-decline');

    if (!banner || !acceptBtn || !declineBtn) return;

    const consent = getCookie('cookie_consent');

    if (!consent) {
      // Show the banner with a beautiful micro-animation
      banner.classList.remove('hidden');
      setTimeout(() => {
        banner.classList.remove('translate-y-6', 'opacity-0');
      }, 300);
    }

    acceptBtn.addEventListener('click', () => {
      setCookie('cookie_consent', 'accepted', 365);
      if (window.loadNonEssentialTracking) {
        window.loadNonEssentialTracking();
      }
      hideBanner();
    });

    declineBtn.addEventListener('click', () => {
      setCookie('cookie_consent', 'declined', 365);
      if (window.nonEssentialTrackingLoaded) {
        hideBanner();
        setTimeout(() => {
          window.location.reload();
        }, 300);
      } else {
        hideBanner();
      }
    });

    function hideBanner() {
      banner.classList.add('translate-y-6', 'opacity-0');
      setTimeout(() => {
        banner.classList.add('hidden');
      }, 500);
    }
  })();
</script>
