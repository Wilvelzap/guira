---
interface Props {
  code: 'us' | 'bo' | 'br' | 'co' | 'mx' | 'eu';
  size?: 'sm' | 'lg';
  class?: string;
}

const { code, size = 'sm', class: className = '' } = Astro.props;

const euStars = Array.from({ length: 12 }, (_, i) => {
  const angle = (i / 12) * 2 * Math.PI - Math.PI / 2;
  const cx = 15 + 6.4 * Math.cos(angle);
  const cy = 10 + 5.6 * Math.sin(angle);
  return { cx: cx.toFixed(2), cy: cy.toFixed(2) };
});
---

<span class={`flag-icon flag-icon-${size} ${className}`} aria-hidden="true">
  <svg viewBox="0 0 30 20" preserveAspectRatio="xMidYMid slice">
    {code === 'us' && (
      <>
        <rect width="30" height="20" fill="#fff" />
        <g fill="#B31942">
          <rect y="0" width="30" height="1.54" />
          <rect y="3.08" width="30" height="1.54" />
          <rect y="6.16" width="30" height="1.54" />
          <rect y="9.24" width="30" height="1.54" />
          <rect y="12.32" width="30" height="1.54" />
          <rect y="15.4" width="30" height="1.54" />
          <rect y="18.46" width="30" height="1.54" />
        </g>
        <rect width="12.5" height="10.8" fill="#0A3161" />
      </>
    )}

    {code === 'bo' && (
      <>
        <rect width="30" height="20" fill="#D52B1E" />
        <rect y="6.67" width="30" height="6.67" fill="#F9E300" />
        <rect y="13.33" width="30" height="6.67" fill="#007A33" />
      </>
    )}

    {code === 'br' && (
      <>
        <rect width="30" height="20" fill="#009739" />
        <polygon points="15,2.4 27.5,10 15,17.6 2.5,10" fill="#FEDD00" />
        <circle cx="15" cy="10" r="4.9" fill="#012169" />
        <path d="M 9.6 9.6 A 5.4 5.4 0 0 1 20.4 10.6" stroke="#fff" stroke-width="0.55" fill="none" />
      </>
    )}

    {code === 'co' && (
      <>
        <rect width="30" height="20" fill="#FCD116" />
        <rect y="10" width="30" height="5" fill="#003893" />
        <rect y="15" width="30" height="5" fill="#CE1126" />
      </>
    )}

    {code === 'mx' && (
      <>
        <rect width="10" height="20" fill="#006847" />
        <rect x="10" width="10" height="20" fill="#fff" />
        <rect x="20" width="10" height="20" fill="#CE1126" />
        <circle cx="15" cy="10" r="2.2" fill="#8B5A2B" />
      </>
    )}

    {code === 'eu' && (
      <>
        <rect width="30" height="20" fill="#003399" />
        {euStars.map((s) => (
          <circle cx={s.cx} cy={s.cy} r="0.85" fill="#FFCC00" />
        ))}
      </>
    )}
  </svg>
</span>
